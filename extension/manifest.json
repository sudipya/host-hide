{
  "manifest_version": 3,
  "name": "HIDE HOST",
  "version": "1.0.0",
  "description": "Explainable WAF-style detection for suspicious web requests.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HIDE HOST"
  },
  "permissions": ["activeTab", "tabs"],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
